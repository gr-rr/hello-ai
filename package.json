{
  "name": "hello-ai",
  "version": "2.0.0",
  "private": true,
  "description": "Music AI Studio — transcribe audio to MIDI and sheet music, and manage your music library.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "commit": "aicommits",
    "ci": "npm run build && npm run lint",
    "check": "bash scripts/check.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:types": "supabase gen types typescript --linked > lib/database.types.ts",
    "precommit": "pre-commit run --all-files"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@sentry/nextjs": "^10.66.0",
    "@supabase/supabase-js": "^2.45.0",
    "abcjs": "^6.6.4",
    "next": "15.5.20",
    "opensheetmusicdisplay": "^2.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "soundfont-player": "^0.12.0",
    "wavesurfer.js": "^7.12.11"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^7.3.6",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.3",
    "aicommits": "^3.4.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
