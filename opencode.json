{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@0.0.78"],
      "enabled": true
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp/giancarlo-ricci/javascript-nextjs",
      "enabled": true,
      "headers": {
        "Authorization": "Sentry-Bearer {env:SENTRY_ACCESS_TOKEN}"
      }
    }
  }
}
