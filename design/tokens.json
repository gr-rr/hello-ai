{
  "name": "hello-ai · music studio",
  "version": 2,
  "description": "Single source of truth for design tokens. Values mirror app/globals.css exactly. Components must consume these tokens, never hardcode values.",
  "color": {
    "bg": "#080515",
    "panel": "#0e0a1f",
    "panel-2": "#161130",
    "panel-3": "#20194a",
    "text": "#eeeaff",
    "muted": "#7b6fa0",
    "accent": "#c084fc",
    "accent-strong": "#a855f7",
    "accent-2": "#f59e0b",
    "accent-soft": "rgba(192,132,252,0.1)",
    "accent-soft-2": "rgba(245,158,11,0.1)",
    "danger": "#ef4444",
    "danger-soft": "rgba(239,68,68,0.1)",
    "success": "#34d399",
    "success-soft": "rgba(52,211,153,0.1)",
    "border": "rgba(255,255,255,0.06)",
    "border-strong": "rgba(255,255,255,0.12)"
  },
  "gradient": {
    "grad-accent": "linear-gradient(135deg, #c084fc, #a855f7, #f59e0b)",
    "grad-accent-2": "linear-gradient(135deg, #a855f7, #f59e0b)"
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "xl": "22px",
    "full": "999px"
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px"
  },
  "typography": {
    "font-sans": "ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
    "font-mono": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
    "scale": {
      "xs": "12px",
      "sm": "13px",
      "base": "15px",
      "md": "17px",
      "lg": "22px",
      "xl": "30px",
      "2xl": "36px"
    },
    "weight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "elevation": {
    "sm": "0 1px 3px rgba(0,0,0,0.4)",
    "md": "0 6px 24px rgba(0,0,0,0.5)",
    "lg": "0 18px 50px rgba(0,0,0,0.6)",
    "ring": "0 0 0 2px rgba(192,132,252,0.3)"
  },
  "motion": {
    "ease": "cubic-bezier(0.22,1,0.36,1)",
    "duration": "200ms"
  },
  "components": {
    "button": { "radius": "md", "padding": "9px 18px", "font-size": "sm", "weight": "medium" },
    "chip": { "radius": "full", "padding": "5px 12px", "font-size": "xs" },
    "card": { "radius": "lg", "padding": "16px", "bg": "panel", "border": "border" },
    "panel": { "radius": "lg", "padding": "16px", "bg": "panel", "border": "border" },
    "input": { "radius": "md", "padding": "8px 12px", "bg": "panel-2", "border": "border" }
  }
}
