{
  "name": "hello-ai · music studio",
  "version": 1,
  "color": {
    "bg": "#0b0d12",
    "panel": "#141821",
    "panel-2": "#1b2030",
    "panel-3": "#232a3a",
    "text": "#e6e9ef",
    "muted": "#9aa4b2",
    "accent": "#6ea8fe",
    "accent-2": "#7c5cff",
    "accent-soft": "rgba(110,168,254,0.14)",
    "danger": "#dc2626",
    "success": "#34d399",
    "border": "#232a3a",
    "border-strong": "#2f3850"
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "xl": "22px",
    "full": "999px"
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px"
  },
  "typography": {
    "font-sans": "ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
    "font-mono": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
    "scale": {
      "xs": "12px",
      "sm": "13px",
      "base": "15px",
      "md": "17px",
      "lg": "22px",
      "xl": "30px",
      "2xl": "42px"
    },
    "weight": { "normal": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },
  "elevation": {
    "sm": "0 1px 2px rgba(0,0,0,0.3)",
    "md": "0 6px 20px rgba(0,0,0,0.35)",
    "lg": "0 18px 50px rgba(0,0,0,0.45)",
    "ring": "0 0 0 3px rgba(110,168,254,0.14)"
  },
  "motion": {
    "ease": "cubic-bezier(0.22,1,0.36,1)",
    "duration": "160ms"
  },
  "components": {
    "button": { "radius": "md", "padding": "8px 14px", "font-size": "sm", "weight": "medium" },
    "chip": { "radius": "full", "padding": "6px 12px", "font-size": "xs" },
    "card": { "radius": "lg", "padding": "20px", "bg": "panel", "border": "border" },
    "panel": { "radius": "lg", "padding": "20px", "bg": "panel", "border": "border" },
    "input": { "radius": "md", "padding": "8px 12px", "bg": "panel-2", "border": "border" }
  }
}
