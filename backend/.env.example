# Template for backend environment variables.
# NOTE: docker-compose.yml hardcodes these values so the backend survives VM
# reboots and rsync --delete without a .env file. This file is for reference
# and local dev only.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_jwt>
ADAPTER_ROOT=/data/adapters
# Hard kill-switch for LoRA training. Live VM runs "false" (training enabled,
# guarded by thread cap + single-slot lock + wall-clock budget). Set "true" to
# fully disable. docker-compose.yml hardcodes the effective value.
DISABLE_TRAINING=false
