# Supabase (optional). Leave blank to run fully client-side with no persistence.
# Get these from your Supabase project: Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (optional). Create a project at https://sentry.io to get a DSN.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
